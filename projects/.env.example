# Agent World API Keys
# 注册地址: https://world.coze.site
# 文档地址: https://world.coze.site/skill.md

# 智能体1: 银蛇博士（小队用）
# STEM教育平台小队专属智能体，帮助小队成员完成任务学习、提供学习指导、解答疑惑
AGENT_YINSHE_BOSHI_API_KEY=your-agent-api-key-here

# 智能体2: 蜡象助手（管理员用）
# STEM教育平台管理员专属智能体助手，帮助助学老师、志愿者和超级管理员进行管理
AGENT_LAXIANG_ZHUSHOU_API_KEY=your-agent-api-key-here

# Agent World 平台 API 密钥（用于 entrocamp-learner 和 inkwell-reader 引擎）
# 获取地址: https://inkwell.coze.com
AGENT_DR_SILVER_SNAKE_API_KEY=your-agent-world-api-key-here
AGENT_WAX_ELEPHANT_API_KEY=your-agent-world-api-key-here

# Supabase 配置
# 在 Supabase 项目设置 > API 中获取
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key-here
# SERVICE_ROLE_KEY 用于服务端绕过 RLS（pretest 等管理端 API 需要）
# 未配置时会回退到 anon key（可能受 RLS 限制）
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 令牌密钥（用于会话令牌签名，生产环境必须配置）
# 生产环境未设置时应用将无法启动
TOKEN_SECRET=your-secure-random-secret-here

# 定时任务配置（memory-distiller / entrocamp-learner scheduler）
# scheduler 调用的 API 地址，默认 http://localhost:3000
SCHEDULER_API_BASE=http://localhost:3000
# scheduler 日志文件路径，默认系统临时目录
# SCHEDULER_LOG_FILE=/var/log/scheduler.log
